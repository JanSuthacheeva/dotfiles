{
  "env": {
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1",
    "CLAUDE_CODE_NEW_INIT": "true"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(make test)",
      "Read(/Users/jansuthacheeva/projects/**)",
      "Glob",
      "Grep",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(go list*)",
      "Bash(go doc*)",
      "Bash(go version*)",
      "Bash(go env*)",
      "Bash(go mod graph*)",
      "Bash(php --version*)",
      "Bash(php -m*)",
      "Bash(php -i*)",
      "Bash(composer show*)",
      "Bash(composer info*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook notification",
            "timeout": 2
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook permission_request",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ccpetline-hook",
            "async": true
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook post_tool_use",
            "timeout": 2
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook pre_compact",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook pre_tool_use",
            "timeout": 2
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccpetline-hook",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook session_end",
            "timeout": 2
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccpetline-hook",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook session_start",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook stop",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook subagent_start",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook subagent_stop",
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-office-hook user_prompt_submit",
            "timeout": 2
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccpetline"
  },
  "enabledPlugins": {
    "buzzwoo-standard@buzzwoo-claude-plugins": true,
    "buzzwoo-web@buzzwoo-claude-plugins": true,
    "caveman@caveman": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "feature-dev@buzzwoo-claude-plugins": true,
    "buzzwoo-web-laravel@buzzwoo-claude-plugins": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "directory",
        "path": "/Users/jansuthacheeva/projects/caveman"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Ugh thinking",
      "Smash rock",
      "Rub two stick",
      "Hunt mammoth",
      "Chase bug",
      "Poke fire",
      "Sharpen spear",
      "Grunt at bytes",
      "Drag log",
      "Paint cave wall",
      "Chew bone",
      "Sniff trail",
      "Bang keyboard",
      "Invent wheel",
      "Follow tracks",
      "Stalk prey",
      "Carve tablet",
      "Summon fire spirit",
      "Count on fingers",
      "Club bug dead"
    ]
  },
  "effortLevel": "high",
  "theme": "custom:aurum",
  "agentPushNotifEnabled": true
}
