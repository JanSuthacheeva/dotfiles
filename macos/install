#!/usr/bin/env bash

set -e

DOTFILES=$(cd $(dirname "${BASH_SOURCE[0]}")/.. && pwd)

echo "Installing macOS dotfiles..."

# Check and install Ghostty
if ! command -v ghostty &> /dev/null; then
    echo "Ghostty not found. Installing via Homebrew..."
    brew install --cask ghostty
else
    echo "Ghostty already installed"
fi

# Set up Ghostty config symlink
echo "Setting up Ghostty config..."
rm -rf $HOME/.config/ghostty
ln -s $DOTFILES/macos/ghostty $HOME/.config/ghostty

# Check and install Neovim
if ! command -v nvim &> /dev/null; then
    echo "Neovim not found. Installing via Homebrew..."
    brew install neovim
else
    echo "Neovim already installed"
fi

# Set up Neovim config symlink
echo "Setting up Neovim config..."
rm -rf $HOME/.config/nvim
ln -s $DOTFILES/nvim $HOME/.config/nvim

# Check and install AeroSpace
if ! command -v aerospace &> /dev/null; then
    echo "AeroSpace not found. Installing via Homebrew..."
    brew install --cask nikitabobko/tap/aerospace
else
    echo "AeroSpace already installed"
fi

# Set up AeroSpace config symlink
echo "Setting up AeroSpace config..."
rm -rf $HOME/.aerospace.toml
ln -s $DOTFILES/macos/aerospace/.aerospace.toml $HOME/.aerospace.toml

# Set up app-icons symlink
echo "Setting up app-icons..."
rm -rf $HOME/.config/app-icons
ln -s $DOTFILES/macos/app-icons $HOME/.config/app-icons

# Check and install Borders
if ! command -v borders &> /dev/null; then
    echo "Borders not found. Installing via Homebrew..."
    brew install borders
else
    echo "Borders already installed"
fi

# Set up Borders config symlink
echo "Setting up Borders config..."
rm -rf $HOME/.config/borders
ln -s $DOTFILES/macos/borders $HOME/.config/borders

# Set up Zsh config
echo "Setting up Zsh config..."
rm -f $HOME/.zshrc
ln -s $DOTFILES/macos/zsh/.zshrc $HOME/.zshrc

# Set up Lazygit config symlink
echo "Setting up Lazygit config..."
rm -rf $HOME/.config/lazygit
ln -s $DOTFILES/lazygit $HOME/.config/lazygit

# Check and install tmux
if ! command -v tmux &> /dev/null; then
    echo "tmux not found. Installing via Homebrew..."
    brew install tmux
else
    echo "tmux already installed"
fi

# Set up tmux config. Symlink the whole dir so ~/.config/tmux/{tmux.conf,
# tmux.reset.conf,plugins} all resolve — tmux.conf references those paths.
echo "Setting up tmux config..."
rm -f $HOME/.tmux.conf
mkdir -p $HOME/.config
rm -rf $HOME/.config/tmux
ln -s $DOTFILES/tmux $HOME/.config/tmux

# Bootstrap tpm and install declared plugins (catppuccin/sensible/battery).
# Plugins live at ~/.config/tmux/plugins -> repo/tmux/plugins (gitignored).
# Best-effort: needs network + tmux; never aborts the install.
if [ ! -d "$HOME/.config/tmux/plugins/tpm" ]; then
    echo "Installing tpm..."
    git clone --depth 1 https://github.com/tmux-plugins/tpm \
        "$HOME/.config/tmux/plugins/tpm" || echo "  tpm clone failed (offline?); run tpm's install_plugins later"
fi
if [ -x "$HOME/.config/tmux/plugins/tpm/bin/install_plugins" ]; then
    echo "Installing tmux plugins..."
    # A throwaway server lets tpm read the @plugin declarations from the config.
    tmux new-session -d -s __bootstrap__ 2>/dev/null || true
    TMUX_PLUGIN_MANAGER_PATH="$HOME/.config/tmux/plugins/" \
        "$HOME/.config/tmux/plugins/tpm/bin/install_plugins" || true
    tmux kill-session -t __bootstrap__ 2>/dev/null || true
fi

# Set up scripts
echo "Setting up scripts..."
mkdir -p $HOME/bin
rm -f $HOME/bin/t
ln -s $DOTFILES/scripts/t $HOME/bin/t

# Set up Claude Code config
echo "Setting up Claude Code config..."
mkdir -p $HOME/.claude
rm -f $HOME/.claude/CLAUDE.md
ln -s $DOTFILES/claude/CLAUDE.md $HOME/.claude/CLAUDE.md
rm -f $HOME/.claude/settings.json
ln -s $DOTFILES/claude/settings.json $HOME/.claude/settings.json
rm -rf $HOME/.claude/themes
ln -s $DOTFILES/claude/themes $HOME/.claude/themes
rm -rf $HOME/.claude/commands
ln -s $DOTFILES/claude/commands $HOME/.claude/commands
rm -rf $HOME/.claude/skills
ln -s $DOTFILES/claude/skills $HOME/.claude/skills

# Seed theme state and generate ghostty's included theme file (see macos/theme).
# Respects an existing choice; defaults to aurum. Switch later with
# `make theme-aurum` / `make theme-spectra`.
echo "Seeding theme..."
current=$(cat "$HOME/.config/theme-current" 2>/dev/null || echo aurum)
case "$current" in aurum|spectra) ;; *) current=aurum ;; esac
"$DOTFILES/macos/theme" "$current"

echo "macOS dotfiles installation complete!"
