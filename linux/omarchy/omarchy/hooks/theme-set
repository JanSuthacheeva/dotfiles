#!/bin/bash
# Omarchy theme-set hook (dotfiles). Runs after `omarchy theme set <name>`.
# 1. Live-reloads the colorscheme in running Neovim instances.
# 2. Fixes the generated Claude theme's "base" (dark/light) from the bg luminance.

THEME_DIR="$HOME/.config/omarchy/current/theme"

# --- 1. Reload Neovim ----------------------------------------------------------
if command -v nvim >/dev/null; then
  runtime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
  for sock in "$runtime"/nvim.*; do
    [[ -S $sock ]] || continue
    # --remote-expr evaluates safely without injecting keystrokes.
    nvim --server "$sock" --remote-expr "execute('colorscheme aurum')" >/dev/null 2>&1 &
  done
fi

# --- 2. Fix Claude theme base --------------------------------------------------
colors="$THEME_DIR/colors.toml"
claude_theme="$THEME_DIR/claude.json"
if [[ -f $colors && -f $claude_theme ]]; then
  bg=$(awk -F'"' '/^background/ {print $2; exit}' "$colors" | tr -d '#')
  if [[ ${#bg} -ge 6 ]]; then
    r=$((16#${bg:0:2})); g=$((16#${bg:2:2})); b=$((16#${bg:4:2}))
    # luminance*1000 to stay in integer math; >=500 means light.
    lum=$(((299 * r + 587 * g + 114 * b) / 255))
    base="dark"; [[ $lum -ge 500 ]] && base="light"
    sed -i -E "s/\"base\": *\"(dark|light)\"/\"base\": \"$base\"/" "$claude_theme"
  fi
fi
